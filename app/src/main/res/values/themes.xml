<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SmartEMAP" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- 系统启动页仅黑色过渡；全屏品牌图由 Compose SplashScreenContent 展示 -->
    <style name="Theme.SmartEMAP.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_empty_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.SmartEMAP</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
